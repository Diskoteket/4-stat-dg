{
  "id": "4-stat-dg",
  "title": "4-Stat DG",
  "description": "Ett lättviktigt rollspelssystem om kompetens, stress och relationer. Karaktärer dör sällan av yttre hot — de bryts ner inifrån.",
  "version": "0.1.8",
  "compatibility": {
    "minimum": "12",
    "verified": "12",
    "maximum": "13"
  },
  "authors": [
    {
      "name": "Tim Wetterek",
      "email": "tim@wetterek.se"
    }
  ],
  "esmodules": [
    "module/4-stat-dg.mjs"
  ],
  "styles": [
    "https://fonts.googleapis.com/css2?family=Share+Tech+Mono&display=swap",
    "styles/4-stat-dg.css"
  ],
  "languages": [
    {
      "lang": "sv",
      "name": "Svenska",
      "path": "lang/sv.json"
    },
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json"
    }
  ],
  "documentTypes": {
    "Actor": {
      "character": {
        "htmlFields": [
          "details.biography"
        ]
      },
      "npc": {
        "htmlFields": [
          "details.biography"
        ]
      }
    },
    "Item": {
      "trait": {
        "htmlFields": [
          "description"
        ]
      },
      "bond": {
        "htmlFields": [
          "description"
        ]
      }
    }
  },
  "primaryTokenAttribute": "willpower.value",
  "secondaryTokenAttribute": "stress.total",
  "grid": {
    "distance": 1,
    "units": "m"
  },
  "initiative": "1d6 + @stats.nerves.value",
  "url": "https://github.com/Diskoteket/4-stat-dg",
  "manifest": "https://github.com/Diskoteket/4-stat-dg/releases/latest/download/system.json",
  "download": "https://github.com/Diskoteket/4-stat-dg/releases/latest/download/4-stat-dg.zip",
  "readme": "README.md",
  "bugs": "https://github.com/Diskoteket/4-stat-dg/issues"
}
