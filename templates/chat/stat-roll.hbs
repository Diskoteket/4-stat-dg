<div class="fourstat-chat stat-roll {{#if success}}success{{else}}failure{{/if}}">
  <header class="chat-header">
    <span class="chat-actor">{{actorName}}</span>
    <span class="chat-stat">{{statLabel}}</span>
    {{#if label}}<span class="chat-label">— {{label}}</span>{{/if}}
  </header>

  <div class="chat-body">
    <div class="dice-row">
      {{#each faces as |face|}}
      <span class="die d6 face-{{face}}">{{face}}</span>
      {{/each}}
    </div>

    <div class="groups">
      {{#each groups as |group|}}
      <span class="group {{#if (eq group.face ../best.face)}}group-best{{/if}}">
        {{#if (gt group.count 1)}}
          {{group.count}}× {{group.face}} = <strong>{{group.sum}}</strong>
        {{else}}
          {{group.face}}
        {{/if}}
      </span>
      {{/each}}
    </div>

    <div class="result-row">
      <span class="result-total">
        <strong>{{total}}</strong> {{localize 'FOURSTAT.Chat.Vs'}} {{threshold}}
      </span>
      <span class="result-status">
        {{#if success}}
          ✓ {{localize 'FOURSTAT.Chat.Success'}}
        {{else}}
          ✗ {{localize 'FOURSTAT.Chat.Failure'}} ({{stressDice}} {{localize 'FOURSTAT.Chat.StressDice'}})
        {{/if}}
      </span>
    </div>

    {{#unless success}}
      {{#if actorId}}
      <div class="chat-actions">
        <button type="button" class="fourstat-action" data-action="apply-stress" data-actor-id="{{actorId}}" data-amount="{{stressDice}}">
          + {{stressDice}} {{localize 'FOURSTAT.Stress.Apply'}}
        </button>
        <button type="button" class="fourstat-action" data-action="protect-with-bond" data-actor-id="{{actorId}}" data-amount="{{stressDice}}">
          {{localize 'FOURSTAT.Bond.ProtectButton'}}
        </button>
      </div>
      {{/if}}
    {{/unless}}
  </div>
</div>
