<form class="{{cssClass}}" autocomplete="off">
  <header class="sheet-header">
    <img class="profile-img" src="{{item.img}}" data-edit="img" />
    <h1><input type="text" name="name" value="{{item.name}}" /></h1>
  </header>

  <section class="sheet-body">
    <div class="form-group">
      <label>{{localize 'FOURSTAT.Trait.Polarity'}}</label>
      <select name="system.polarity">
        <option value="positive" {{#if (eq item.system.polarity "positive")}}selected{{/if}}>{{localize 'FOURSTAT.Trait.Positive'}}</option>
        <option value="negative" {{#if (eq item.system.polarity "negative")}}selected{{/if}}>{{localize 'FOURSTAT.Trait.Negative'}}</option>
      </select>
    </div>

    <div class="form-group">
      <label>{{localize 'FOURSTAT.Description'}}</label>
      {{editor descriptionHTML target="system.description" button=true editable=editable}}
    </div>
  </section>
</form>
