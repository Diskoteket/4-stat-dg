<form>
  <div class="form-group">
    <label>{{localize 'FOURSTAT.Roll.Stat'}}</label>
    <div><strong>{{statLabel}}</strong></div>
  </div>
  <div class="form-group">
    <label>{{localize 'FOURSTAT.Roll.Threshold'}}</label>
    <select name="threshold">
      {{#each thresholds as |t|}}
      <option value="{{t.value}}" {{#if (eq t.value 4)}}selected{{/if}}>
        {{t.value}}{{#if t.label}} — {{localize t.label}}{{/if}}
      </option>
      {{/each}}
    </select>
  </div>
  <div class="form-group">
    <label>{{localize 'FOURSTAT.Roll.Trait'}}</label>
    <select name="trait">
      <option value="">{{localize 'FOURSTAT.Roll.NoTrait'}}</option>
      {{#each traits as |t|}}
      <option value="{{t.id}}">{{t.name}} — {{#if (eq t.system.polarity "positive")}}+1{{else}}−1{{/if}}</option>
      {{/each}}
    </select>
  </div>
  <div class="form-group">
    <label>{{localize 'FOURSTAT.Roll.Note'}}</label>
    <input type="text" name="label" placeholder="{{localize 'FOURSTAT.Roll.NotePlaceholder'}}" />
  </div>
</form>
