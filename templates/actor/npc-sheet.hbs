<form class="{{cssClass}}" autocomplete="off">
  <header class="sheet-header">
    <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" />
    <div class="header-fields">
      <h1><input name="name" type="text" value="{{actor.name}}" /></h1>
      <label>{{localize 'FOURSTAT.NPC.Threat'}}
        <select name="system.threat">
          <option value="minor" {{#if (eq actor.system.threat "minor")}}selected{{/if}}>{{localize 'FOURSTAT.NPC.ThreatMinor'}}</option>
          <option value="standard" {{#if (eq actor.system.threat "standard")}}selected{{/if}}>{{localize 'FOURSTAT.NPC.ThreatStandard'}}</option>
          <option value="major" {{#if (eq actor.system.threat "major")}}selected{{/if}}>{{localize 'FOURSTAT.NPC.ThreatMajor'}}</option>
        </select>
      </label>
    </div>
  </header>

  <section class="sheet-body">
    <section class="stats">
      <h2>{{localize 'FOURSTAT.Section.Stats'}}</h2>
      <div class="stat-grid">
        {{#each stats}}
        <div class="stat">
          <button type="button" class="stat-roll" data-action="roll-stat" data-stat="{{key}}">
            <span class="stat-label">{{localize label}}</span>
            <span class="stat-value">{{value}}</span>
          </button>
          <input type="number" name="system.stats.{{key}}.value" value="{{value}}" min="0" max="5" />
        </div>
        {{/each}}
      </div>
    </section>

    <section class="biography">
      <h2>{{localize 'FOURSTAT.NPC.Notes'}}</h2>
      {{editor actor.system.notes target="system.notes" button=true editable=editable}}
    </section>
  </section>
</form>
